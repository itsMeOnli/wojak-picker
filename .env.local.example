# Public base URL where your self-hosted Wojak library is served.
# Used by scripts/build-deploy.js to rewrite manifest URLs, and matches the
# "Library Base URL" preference in the Raycast extension.
WOJAK_BASE_URL=https://wojaks.example.com

# SSH target for scripts/deploy-vps.sh (rsync upload).
VPS_HOST=user@your-vps
# Optional overrides:
# VPS_PATH=/var/www/wojaks
# SSH_PORT=22
