{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "wojak-picker",
  "title": "Wojak Picker",
  "description": "Browse, search, and copy Wojaks straight into any chat from Raycast.",
  "icon": "icon.png",
  "author": "itsmeonli",
  "categories": ["Fun"],
  "license": "MIT",
  "preferences": [
    {
      "name": "baseUrl",
      "type": "textfield",
      "required": false,
      "title": "Library Base URL",
      "description": "Where Wojak images are served from. Defaults to the public jsDelivr CDN. Override to point at your own host (e.g. https://wojaks.example.com).",
      "default": "https://cdn.jsdelivr.net/gh/itsMeOnli/wojak-assets@main"
    }
  ],
  "commands": [
    {
      "name": "search-wojaks",
      "title": "Search Wojaks",
      "description": "Search and copy wojak images",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.68.0",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "build:deploy": "node scripts/build-deploy.js",
    "deploy": "bash scripts/deploy-vps.sh",
    "publish": "ray publish",
    "scrape": "node scrape/scrape.js"
  }
}
